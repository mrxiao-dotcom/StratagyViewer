<Window x:Class="StrategyViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="策略验证工具" Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#b4befe"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475a"/>
                                <Setter Property="Foreground" Value="#6c7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#a6e3a1"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#45475a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3b3d4f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#89b4fa"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6c7086"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#313244" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="策略验证工具" FontSize="20" FontWeight="Bold" Foreground="#89b4fa" VerticalAlignment="Center"/>
                    <Border Background="#a6e3a1" CornerRadius="4" Padding="8,4" Margin="16,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsStrategyServerConfigured, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="策略服务已连接" Foreground="#1e1e2e" FontSize="11"/>
                    </Border>
                    <Border Background="#f9e2af" CornerRadius="4" Padding="8,4" Margin="8,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsMarketServerConfigured, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="行情服务已连接" Foreground="#1e1e2e" FontSize="11"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <Button Content="刷新策略" Command="{Binding LoadStrategiesCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                    <Button Content="清空缓存" Command="{Binding ClearCacheCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0" ToolTip="清空本地缓存数据"/>
                    <Button Content="服务器设置" Command="{Binding OpenSettingsCommand}" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧策略列表 -->
            <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="策略列表" Style="{StaticResource HeaderText}"/>

                            <Button Grid.Column="1" Content="列表视图" Click="OpenDirectionMatrix_Click"
                                    Style="{StaticResource SecondaryButton}" Padding="12,6" FontSize="12"
                                    VerticalAlignment="Center" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsCacheLoaded}"/>

                            <Button Grid.Column="2" Content="搜索品种" Click="OpenContractSearch_Click"
                                    Style="{StaticResource SecondaryButton}" Padding="12,6" FontSize="12"
                                    VerticalAlignment="Center"/>
                        </Grid>

                    <TreeView Grid.Row="1" x:Name="StrategyTreeView"
                              ItemsSource="{Binding StrategyGroups}"
                              SelectedItemChanged="StrategyTreeView_SelectedItemChanged"
                              Background="Transparent" Foreground="#cdd6f4"
                              BorderThickness="0">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Foreground" Value="#cdd6f4"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▼" Foreground="#6c7086" Margin="0,0,6,0" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#89b4fa" FontSize="14"/>
                                    <TextBlock Text="{Binding Count, StringFormat=' ({0})'}" Foreground="#6c7086" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2"
                                                   MouseLeftButtonDown="StrategyItem_MouseLeftButtonDown" Cursor="Hand">
                                            <TextBlock Text="▶" Foreground="#a6e3a1" Margin="0,0,6,0" FontSize="10" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#a6e3a1" FontSize="12" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#45475a" CornerRadius="4" Padding="8,5" Margin="20,1,0,1" Cursor="Hand"
                                                        MouseLeftButtonDown="ContractItem_MouseLeftButtonDown">
                                                    <TextBlock Text="{Binding Name}" Foreground="#f9e2af" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>
                                    </HierarchicalDataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0" Visibility="{Binding StrategyStats, Converter={StaticResource NullToVisibilityConverter}}">
                        <Border Background="#45475a" CornerRadius="4" Padding="12">
                            <StackPanel>
                                <TextBlock Text="统计信息" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="策略总数" Style="{StaticResource LabelText}"/>
                                        <TextBlock Text="{Binding StrategyStats.TotalStrategies}" Style="{StaticResource ValueText}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="品种总数" Style="{StaticResource LabelText}"/>
                                        <TextBlock Text="{Binding StrategyStats.TotalItems}" Style="{StaticResource ValueText}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" Width="5" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- 右侧内容区 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 选中品种详情卡片 -->
                <Border Style="{StaticResource CardStyle}" Grid.Row="0"
                        Visibility="{Binding CurrentContractSummary, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentContractSummary.Contract}" FontSize="18" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding CurrentContractSummary.Direction}" Foreground="#89dceb"/>
                                    <TextBlock Text=" | " Foreground="#6c7086"/>
                                    <TextBlock Text="{Binding CurrentStrategy.Title}" Foreground="#6c7086"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="入场:" Foreground="#6c7086"/>
                            <TextBlock Text="{Binding CurrentContractSummary.EntryRange}" Margin="8,0,24,0"/>
                            <TextBlock Text="止损:" Foreground="#6c7086"/>
                            <TextBlock Text="{Binding CurrentContractSummary.StopLoss}" Margin="8,0,24,0"/>
                            <TextBlock Text="止盈:" Foreground="#6c7086"/>
                            <TextBlock Text="{Binding CurrentContractSummary.TakeProfit}" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 回测结果区域 -->
                <Grid Grid.Row="2" Visibility="{Binding BacktestResult, Converter={StaticResource NullToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="180"/>
                        </Grid.RowDefinitions>

                        <!-- 回测摘要 -->
                        <Border Style="{StaticResource CardStyle}" Grid.Row="0" Margin="0,8,8,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="盈亏" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BacktestResult.PnL, StringFormat='{}{0:F2}'}"
                                               FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{Binding BacktestResult.PnL, Converter={StaticResource PnLColorConverter}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="结果" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BacktestResult.Result}"
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#f9e2af"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="开仓手数" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BacktestResult.Lots}"
                                               FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#89dceb"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="开仓时间" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BacktestResult.OpenTime, StringFormat='{}{0:HH:mm}'}"
                                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#cdd6f4"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                    <TextBlock Text="开仓原因" Style="{StaticResource LabelText}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding BacktestResult.OpenReason}"
                                               FontSize="12" Foreground="#6c7086" TextWrapping="Wrap" MaxWidth="150"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- K线图表（蜡烛图） -->
                        <Border Style="{StaticResource CardStyle}" Grid.Row="1" Margin="0,8,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="K-Line Chart" Style="{StaticResource HeaderText}"/>
                                <Canvas x:Name="KlineCanvas" Grid.Row="1" Background="#313244" ClipToBounds="True"/>
                            </Grid>
                        </Border>

                        <!-- 资金曲线 -->
                        <Border Style="{StaticResource CardStyle}" Grid.Row="2" Margin="0,8,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Equity Curve" Style="{StaticResource HeaderText}"/>
                                <lvc:CartesianChart Grid.Row="1" Series="{Binding EquityCurveSeries}" XAxes="{Binding EquityXAxes}" YAxes="{Binding EquityYAxes}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 右侧K线明细列表 -->
                    <Border Style="{StaticResource CardStyle}" Grid.Column="1" Margin="0,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="K-Line Detail" Style="{StaticResource HeaderText}" Margin="0"/>
                                <Border Background="#45475a" CornerRadius="4" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding BacktestResult.Result}" Foreground="#f9e2af" FontSize="11"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="入场:" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding BacktestResult.EntryPrice, StringFormat='{}{0:F2}'}" Foreground="#a6e3a1" Margin="4,0,16,0" FontSize="11"/>
                                <TextBlock Text="止损:" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding BacktestResult.StopLoss, StringFormat='{}{0:F2}'}" Foreground="#f38ba8" Margin="4,0,16,0" FontSize="11"/>
                                <TextBlock Text="止盈:" Foreground="#6c7086" FontSize="11"/>
                                <TextBlock Text="{Binding BacktestResult.TakeProfit, StringFormat='{}{0:F2}'}" Foreground="#89dceb" Margin="4,0,0,0" FontSize="11"/>
                            </StackPanel>

                            <DataGrid Grid.Row="2" ItemsSource="{Binding BacktestResult.KLineResults}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" Foreground="#cdd6f4"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#45475a"
                                      HeadersVisibility="Column"
                                      RowBackground="#313244"
                                      AlternatingRowBackground="#3b3d4f"
                                      CanUserResizeRows="False"
                                      FrozenColumnCount="1">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#45475a"/>
                                        <Setter Property="Foreground" Value="#cdd6f4"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="#cdd6f4"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Action}" Value="开仓">
                                                <Setter Property="Background" Value="#45475a"/>
                                                <Setter Property="Foreground" Value="#a6e3a1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Action}" Value="止损">
                                                <Setter Property="Background" Value="#45475a"/>
                                                <Setter Property="Foreground" Value="#f38ba8"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Action}" Value="止盈">
                                                <Setter Property="Background" Value="#45475a"/>
                                                <Setter Property="Foreground" Value="#89dceb"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Date, StringFormat='{}{0:MM-dd HH:mm}'}" Width="110"/>
                                        <DataGridTextColumn Header="Open" Binding="{Binding Open, StringFormat='{}{0:F2}'}" Width="65"/>
                                        <DataGridTextColumn Header="High" Binding="{Binding High, StringFormat='{}{0:F2}'}" Width="65"/>
                                        <DataGridTextColumn Header="Low" Binding="{Binding Low, StringFormat='{}{0:F2}'}" Width="65"/>
                                        <DataGridTextColumn Header="Close" Binding="{Binding Close, StringFormat='{}{0:F2}'}" Width="65"/>
                                        <DataGridTextColumn Header="Float PnL" Binding="{Binding FloatingPnL, StringFormat='{}{0:F0}'}" Width="75"/>
                                        <DataGridTextColumn Header="Signal" Binding="{Binding Action}" Width="50"/>
                                    </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 无数据提示 -->
                <Border Grid.Row="0" Grid.RowSpan="3" Style="{StaticResource CardStyle}"
                        Visibility="{Binding CurrentContractSummary, Converter={StaticResource InverseNullToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="64" Foreground="#45475a" HorizontalAlignment="Center"/>
                        <TextBlock Text="选择左侧品种查看验证结果" FontSize="18" Foreground="#6c7086" Margin="0,16,0,0" HorizontalAlignment="Center"/>
                        <TextBlock Text="点击策略下的具体品种" FontSize="12" Foreground="#4c4f5e" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#313244" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#6c7086"/>
                <ProgressBar Grid.Column="1" IsIndeterminate="{Binding IsLoading}" Width="100" Height="4"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#45475a" Foreground="#89b4fa"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3" Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="加载中..." FontSize="18" Foreground="#cdd6f4"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
