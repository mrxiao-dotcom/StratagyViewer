<Window x:Class="StrategyViewer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器设置" Height="850" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e1e2e">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#b4befe"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <TextBlock Text="策略信号服务器" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#89b4fa"/>

            <GroupBox Header="策略服务器配置">
                <StackPanel>
                    <TextBlock Text="服务器地址" Margin="0,0,0,4"/>
                    <TextBox x:Name="StrategyUrlTextBox" Margin="0,0,0,12"/>

                    <TextBlock Text="访问令牌 (Token)" Margin="0,0,0,4"/>
                    <TextBox x:Name="StrategyTokenTextBox"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="行情数据服务器" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#89b4fa"/>

            <GroupBox Header="行情服务器配置">
                <StackPanel>
                    <TextBlock Text="服务器地址" Margin="0,0,0,4"/>
                    <TextBox x:Name="MarketUrlTextBox"/>
                    <TextBlock Text="（行情服务器无需Token）" Foreground="#6c7086" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="验证设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#89b4fa"/>

            <GroupBox Header="分析参数">
                <StackPanel>
                    <TextBlock Text="验证天数（信号发出后）" Margin="0,0,0,4"/>
                    <TextBox x:Name="AnalysisDaysTextBox" Width="100" HorizontalAlignment="Left"/>
                    
                    <TextBlock Text="单笔止损金额（元）" Margin="0,12,0,4"/>
                    <TextBlock Text="用于以损定量计算开仓手数" Foreground="#6c7086" FontSize="11" Margin="0,0,0,8"/>
                    <TextBox x:Name="StopLossAmountTextBox" Width="100" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="飞书通知" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#89b4fa"/>

            <GroupBox Header="飞书机器人配置">
                <StackPanel>
                    <CheckBox x:Name="FeishuEnabledCheckBox" Content="启用飞书通知" Foreground="#cdd6f4" Margin="0,0,0,12"/>

                    <TextBlock Text="Webhook 地址" Margin="0,0,0,4"/>
                    <TextBox x:Name="FeishuWebhookTextBox" Margin="0,0,0,12"/>

                    <TextBlock Text="机器人名称" Margin="0,0,0,4"/>
                    <TextBox x:Name="FeishuBotNameTextBox"/>
                    <TextBlock Text="显示在飞书消息中的机器人名称" Foreground="#6c7086" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="飞书图片发送" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#89b4fa"/>

            <GroupBox Header="飞书传图机器人配置">
                <StackPanel>
                    <CheckBox x:Name="FeishuImageEnabledCheckBox" Content="启用飞书传图" Foreground="#cdd6f4" Margin="0,0,0,12"/>
                    <TextBlock Text="使用飞书机器人发送矩阵图片，支持更丰富的展示效果" Foreground="#6c7086" FontSize="11" Margin="0,-4,0,12"/>

                    <TextBlock Text="App ID" Margin="0,0,0,4"/>
                    <TextBox x:Name="FeishuImageAppIdTextBox" Margin="0,0,0,12"/>

                    <TextBlock Text="App Secret" Margin="0,0,0,4"/>
                    <TextBox x:Name="FeishuImageAppSecretTextBox" Margin="0,0,0,12"/>

                    <TextBlock Text="Chat ID" Margin="0,0,0,4"/>
                    <TextBox x:Name="FeishuImageChatIdTextBox" Margin="0,0,0,12"/>

                    <CheckBox x:Name="FeishuImageUseCardCheckBox" Content="在图片上方添加卡片标题" Foreground="#cdd6f4" IsChecked="True"/>
                    <TextBlock Text="启用后会在图片上方显示标题、时间和免责声明" Foreground="#6c7086" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="Telegram 通知" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#89b4fa"/>

            <GroupBox Header="Telegram 机器人配置">
                <StackPanel>
                    <CheckBox x:Name="TelegramEnabledCheckBox" Content="启用 Telegram 通知" Foreground="#cdd6f4" Margin="0,0,0,12"/>

                    <TextBlock Text="Bot Token" Margin="0,0,0,4"/>
                    <TextBox x:Name="TelegramBotTokenTextBox" Margin="0,0,0,12"/>
                    <TextBlock Text="从 @BotFather 获取的 Token" Foreground="#6c7086" FontSize="11" Margin="0,-8,0,8"/>

                    <TextBlock Text="Chat ID（支持多个，用分号分隔）" Margin="0,0,0,4"/>
                    <TextBox x:Name="TelegramChatIdTextBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>
                    <TextBlock Text="格式如: -1001234567890;-1009876543210" Foreground="#6c7086" FontSize="11" Margin="0,0,0,8"/>

                    <Button x:Name="TestTelegramButton" Content="测试 Telegram 连接" Click="TestTelegram_Click" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="测试连接" Click="TestConnection_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
            <Button Content="保存" Click="Save_Click" Margin="0,0,12,0"/>
            <Button Content="取消" Click="Cancel_Click" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
