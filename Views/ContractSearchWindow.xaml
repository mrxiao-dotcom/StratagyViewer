<Window x:Class="StrategyViewer.Views.ContractSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StrategyViewer.Views"
        xmlns:converters="clr-namespace:StrategyViewer.Converters"
        Title="品种策略搜索" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e"
        ResizeMode="CanResize">
    <Window.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#b4befe"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475a"/>
                                <Setter Property="Foreground" Value="#6c7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#45475a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3b3d4f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Text="品种策略搜索" FontSize="20" FontWeight="Bold" Foreground="#89b4fa" Margin="0,0,0,16"/>

        <!-- 品种分类按钮区域 -->
        <Border Grid.Row="1" Background="#313244" CornerRadius="8" Padding="12" Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="快速搜索" FontSize="12" Foreground="#6c7086" Margin="0,0,0,10"/>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 分类标题 -->
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#89b4fa"
                                           VerticalAlignment="Center" FontSize="12"/>

                                <!-- 品种按钮 -->
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Products}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding DisplayName}"
                                                    Click="ProductButton_Click"
                                                    Tag="{Binding DisplayName}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Padding="10,5"
                                                    Margin="0,0,8,4"
                                                    FontSize="12"
                                                    MinWidth="60"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- 搜索框区域 -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchTextBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="SearchTextBox_KeyDown">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <Button Grid.Column="1" Content="搜索" Command="{Binding SearchCommand}" Margin="12,0,0,0" Width="100"/>
        </Grid>

        <!-- 主内容区：左右结构 -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：策略列表 -->
            <Border Grid.Column="0" Background="#313244" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 结果统计 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12"
                                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="搜索结果: " Foreground="#6c7086"/>
                        <TextBlock Text="{Binding Results.Count}" Foreground="#89b4fa" FontWeight="Bold"/>
                        <TextBlock Text=" 条记录" Foreground="#6c7086"/>
                    </StackPanel>

                    <!-- 分组切换按钮 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12"
                                Visibility="{Binding HasResults, Converter={StaticResource BoolToVisibilityConverter}}">
                        <RadioButton Content="按策略类型" IsChecked="{Binding GroupByStrategyType}"
                                     Foreground="#cdd6f4" Margin="0,0,16,0"/>
                        <RadioButton Content="按日期" IsChecked="{Binding GroupByStrategyType, Converter={StaticResource InverseBoolConverter}}"
                                     Foreground="#cdd6f4"/>
                    </StackPanel>

                    <!-- 策略列表（按策略类型分组） -->
                    <ListBox Grid.Row="2" x:Name="StrategiesList"
                             ItemsSource="{Binding GroupedByStrategyType}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Visibility="{Binding GroupByStrategyType, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- 策略类型标题 -->
                                    <Border Background="#45475a" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StrategyType}" FontWeight="SemiBold" Foreground="#89b4fa"/>
                                            <TextBlock Text=" (" Foreground="#6c7086"/>
                                            <TextBlock Text="{Binding ItemCount}" Foreground="#89b4fa"/>
                                            <TextBlock Text=")" Foreground="#6c7086"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- 该类型的策略 -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#3b3d4f" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="StrategyItem_MouseLeftButtonDown">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 第一行：策略名 + 方向 -->
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="{Binding StrategyTitle}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   Foreground="#cdd6f4"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <Border Grid.Row="0" Grid.Column="1" Padding="8,2" CornerRadius="4" Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#45475a"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="多">
                                                                            <Setter Property="Background" Value="#a6e3a1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="做多">
                                                                            <Setter Property="Background" Value="#a6e3a1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="空">
                                                                            <Setter Property="Background" Value="#f38ba8"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="做空">
                                                                            <Setter Property="Background" Value="#f38ba8"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Direction}" FontSize="11" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#cdd6f4"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="多">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="做多">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="空">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="做空">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- 第二行：价格信息 -->
                                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="入场: " Foreground="#6c7086" FontSize="11"/>
                                                            <TextBlock Text="{Binding EntryRange}" Foreground="#a6e3a1" FontSize="11"/>
                                                            <TextBlock Text="  止损: " Foreground="#6c7086" FontSize="11" Margin="8,0,0,0"/>
                                                            <TextBlock Text="{Binding StopLoss}" Foreground="#f38ba8" FontSize="11"/>
                                                            <TextBlock Text="  止盈: " Foreground="#6c7086" FontSize="11" Margin="8,0,0,0"/>
                                                            <TextBlock Text="{Binding TakeProfit}" Foreground="#89dceb" FontSize="11"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 策略列表（按日期分组） -->
                    <ListBox Grid.Row="2" x:Name="DateListBox"
                             ItemsSource="{Binding GroupedByDate}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Visibility="{Binding GroupByStrategyType, Converter={StaticResource InverseBoolConverter}}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- 日期标题 -->
                                    <Border Background="#45475a" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding DateString}" FontWeight="SemiBold" Foreground="#89b4fa"/>
                                    </Border>
                                    <!-- 该日期的策略 -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#3b3d4f" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="StrategyItem_MouseLeftButtonDown">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 第一行：策略名 + 方向 -->
                                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                                   Text="{Binding StrategyTitle}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   Foreground="#cdd6f4"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <Border Grid.Row="0" Grid.Column="1" Padding="8,2" CornerRadius="4" Margin="8,0,0,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#45475a"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="多">
                                                                            <Setter Property="Background" Value="#a6e3a1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="做多">
                                                                            <Setter Property="Background" Value="#a6e3a1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="空">
                                                                            <Setter Property="Background" Value="#f38ba8"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Direction}" Value="做空">
                                                                            <Setter Property="Background" Value="#f38ba8"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Direction}" FontSize="11" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#cdd6f4"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="多">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="做多">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="空">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Direction}" Value="做空">
                                                                                <Setter Property="Foreground" Value="#1e1e2e"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- 第二行：价格信息 -->
                                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="入场: " Foreground="#6c7086" FontSize="11"/>
                                                            <TextBlock Text="{Binding EntryRange}" Foreground="#a6e3a1" FontSize="11"/>
                                                            <TextBlock Text="  止损: " Foreground="#6c7086" FontSize="11" Margin="8,0,0,0"/>
                                                            <TextBlock Text="{Binding StopLoss}" Foreground="#f38ba8" FontSize="11"/>
                                                            <TextBlock Text="  止盈: " Foreground="#6c7086" FontSize="11" Margin="8,0,0,0"/>
                                                            <TextBlock Text="{Binding TakeProfit}" Foreground="#89dceb" FontSize="11"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 无数据提示 -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding ShowNoResults, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="未找到相关策略" FontSize="14" Foreground="#6c7086" HorizontalAlignment="Center"/>
                        <TextBlock Text="请输入品种名称进行搜索" FontSize="12" Foreground="#45475a" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 搜索提示 -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding ShowSearchHint, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="输入品种名称搜索" FontSize="14" Foreground="#6c7086" HorizontalAlignment="Center"/>
                        <TextBlock Text="例如: RB, IC, AU, 螺纹钢 等" FontSize="12" Foreground="#45475a" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右侧：K线图表 -->
            <Border Grid.Column="1" Background="#313244" CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 图例 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Rectangle Width="12" Height="12" Fill="#a6e3a1"/>
                            <TextBlock Text="阳线(上涨)" Foreground="#a6e3a1" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Rectangle Width="12" Height="12" Fill="#f38ba8"/>
                            <TextBlock Text="阴线(下跌)" Foreground="#f38ba8" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Line X1="0" Y1="6" X2="12" Y2="6" Stroke="#a6e3a1" StrokeThickness="2" StrokeDashArray="2,1"/>
                            <TextBlock Text="入场价" Foreground="#a6e3a1" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Line X1="0" Y1="6" X2="12" Y2="6" Stroke="#f38ba8" StrokeThickness="2" StrokeDashArray="2,1"/>
                            <TextBlock Text="止损价" Foreground="#f38ba8" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Line X1="0" Y1="6" X2="12" Y2="6" Stroke="#89b4fa" StrokeThickness="2" StrokeDashArray="2,1"/>
                            <TextBlock Text="止盈价" Foreground="#89b4fa" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- K线图表 -->
                    <local:KLineChartControl Grid.Row="1"
                                            KLineData="{Binding KLineData}"
                                            Signals="{Binding ChartSignals}"
                                            EntryPrice="{Binding CurrentEntryPrice}"
                                            StopLoss="{Binding CurrentStopLoss}"
                                            TakeProfit="{Binding CurrentTakeProfit}"
                                            ClipToBounds="True"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading -->
        <Border Grid.Row="3" Background="#80000000" CornerRadius="8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="搜索中..." FontSize="16" Foreground="#cdd6f4"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
